rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function ownsDoc() {
      return isOwner(request.resource.data.uid);
    }

    match /users/{uid} {
      allow read, update: if isOwner(uid);
      allow create: if isOwner(uid);
      allow delete: if false;
    }

    function isOwnedByCaller() {
      return isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // Per-user collections — every doc must carry a matching uid field.
    match /journal/{docId} {
      allow read, update, delete: if isOwnedByCaller();
      allow create: if isSignedIn() && ownsDoc();
    }
    match /backtesting/{docId} {
      allow read, update, delete: if isOwnedByCaller();
      allow create: if isSignedIn() && ownsDoc();
    }
    match /notes/{docId} {
      allow read, update, delete: if isOwnedByCaller();
      allow create: if isSignedIn() && ownsDoc();
    }
    match /settings/{docId} {
      allow read, update, delete: if isOwnedByCaller();
      allow create: if isSignedIn() && ownsDoc();
    }
    match /goals/{docId} {
      allow read, update, delete: if isOwnedByCaller();
      allow create: if isSignedIn() && ownsDoc();
    }
    match /checklists/{docId} {
      allow read, update, delete: if isOwnedByCaller();
      allow create: if isSignedIn() && ownsDoc();
    }
    match /watchlist/{docId} {
      allow read, update, delete: if isOwnedByCaller();
      allow create: if isSignedIn() && ownsDoc();
    }
    match /calendar/{docId} {
      allow read, update, delete: if isOwnedByCaller();
      allow create: if isSignedIn() && ownsDoc();
    }

    // --- Ported from Phase 2/5 (trading-journal) ---
    // These collections use a `userId` field (not `uid`) per the ported
    // tradesService/backtestService/strategyService — kept as-is rather
    // than rewriting the already-working service code.
    function isOwnedByUserId() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }
    function ownsDocByUserId() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /trades/{tradeId} {
      allow read, update, delete: if isOwnedByUserId();
      allow create: if ownsDocByUserId();
    }
    match /strategies/{strategyId} {
      allow read, update, delete: if isOwnedByUserId();
      allow create: if ownsDocByUserId();
    }
    match /backtests/{entryId} {
      allow read, update, delete: if isOwnedByUserId();
      allow create: if ownsDocByUserId();
    }
  }
}
