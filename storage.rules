rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Each user can only read/write files under their own uid folder.
    // e.g. /journal-screenshots/{uid}/trade123.png, /voice-notes/{uid}/note1.webm
    match /{collection}/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024; // 10MB max per file
    }
  }
}
